# =============================================================================
# Autor:   Diego Regis M. F. dos Santos
# Email:   diego-f-santos@openlabs.com.br
# Time:    OpenLabs - DevOps | Infra
# Versão:  2.0.0
# Arquivo: .env.example
# Desc:    Copie para .env e preencha os valores reais
#          NUNCA commite o arquivo .env
# =============================================================================

# ── SMTP / Office 365 ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=seu_usuario@seudominio.com.br
# Se MFA estiver ativo, use um App Password em:
# https://mysignins.microsoft.com/security-info
SMTP_PASSWORD=sua_senha_ou_app_password
SMTP_FROM_NAME=OpenLabs DevOps
SMTP_FROM_EMAIL=noreply@seudominio.com.br

# ── Destinatários ─────────────────────────────────────────────────────────────
EMAIL_TO=ops@seudominio.com.br,gestor@seudominio.com.br
EMAIL_CC=
EMAIL_BCC=
EMAIL_REPLY_TO=

# ── Microsoft Teams ───────────────────────────────────────────────────────────
# Criar em: Teams → Canal → ... → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://sua-org.webhook.office.com/webhookb2/...

# ── Slack ──────────────────────────────────────────────────────────────────────
# Criar em: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_CHANNEL=#devops-alerts

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Múltiplos clusters separados por vírgula (mesma ordem dos contexts)
K8S_CLUSTERS=rkeopl
K8S_CONTEXTS=
# Deixe K8S_CONTEXTS vazio para usar o context atual (in-cluster ServiceAccount)

# ── Diretórios de saída ───────────────────────────────────────────────────────
OUTPUT_DIR=./reports
CACHE_DIR=./cache
